{
  "metadata": {
    "packName": "Synthetic Telemetry Schema for Banking Finance E5 Simulations",
    "version": "1.0",
    "language": "en-US",
    "industry": "Banking and Financial Services",
    "fictionalDataOnly": true,
    "purpose": "Define a normalized schema for synthetic Microsoft 365 E5, Purview, Defender, DLP, Copilot, identity, endpoint, Power BI, and insider-risk-style telemetry generated by browser-based agents."
  },
  "schemaPrinciples": [
    "Use one normalized event schema for cross-workload timeline replay and Power BI reporting.",
    "Preserve workload-specific fields in an AdditionalProperties object.",
    "Use ScenarioId, TaskPlanId, TimelineId, and CorrelationId to connect multi-step activities.",
    "Use stable fictional identifiers for users, files, devices, customers, accounts, cases, and incidents.",
    "Keep raw sensitive-looking values synthetic and clearly marked as fictional.",
    "Support both event-level investigation and aggregated executive reporting."
  ],
  "coreEventSchema": {
    "tableName": "SyntheticM365ActivityEvents",
    "description": "Unified synthetic activity event table for all workloads.",
    "fields": [
      {"name": "EventId", "type": "string", "required": true, "example": "EVT-BF-20260524-000001", "description": "Unique synthetic event identifier."},
      {"name": "TimeGenerated", "type": "datetime", "required": true, "example": "2026-05-24T14:35:22Z", "description": "UTC timestamp for the synthetic event."},
      {"name": "ScenarioId", "type": "string", "required": false, "example": "BF-SCEN-0030", "description": "Complex scenario identifier."},
      {"name": "TaskPlanId", "type": "string", "required": false, "example": "TASKPLAN-0010", "description": "Browser-agent task plan identifier."},
      {"name": "TimelineId", "type": "string", "required": false, "example": "IR-TL-0001", "description": "Insider-risk timeline identifier."},
      {"name": "CorrelationId", "type": "string", "required": false, "example": "CORR-DEVON-20260524-001", "description": "Correlation ID connecting multiple events within the same activity chain."},
      {"name": "UserPrincipalName", "type": "string", "required": true, "example": "devon.reyes@contoso.example", "description": "Synthetic user principal name."},
      {"name": "PersonaName", "type": "string", "required": true, "example": "Devon Reyes", "description": "Synthetic persona display name."},
      {"name": "UserRole", "type": "string", "required": false, "example": "Junior Operations Analyst", "description": "Persona business role."},
      {"name": "Department", "type": "string", "required": false, "example": "Customer Operations", "description": "Persona department."},
      {"name": "Workload", "type": "string", "required": true, "example": "SharePoint Online", "description": "Microsoft 365, Purview, Defender, endpoint, or AI workload."},
      {"name": "Operation", "type": "string", "required": true, "example": "FileDownloaded", "description": "Normalized synthetic operation name."},
      {"name": "SignalCategory", "type": "string", "required": false, "example": "File Lifecycle Activity", "description": "Mapped signal category from purview-signal-correlation.json."},
      {"name": "Severity", "type": "string", "required": false, "allowedValues": ["Informational", "Low", "Medium", "High", "Critical"], "example": "High", "description": "Synthetic severity rating."},
      {"name": "RiskScore", "type": "int", "required": false, "example": 78, "description": "Synthetic risk score from 0 to 100."},
      {"name": "IsRiskEvent", "type": "bool", "required": true, "example": true, "description": "Indicates whether the event should count as a risk event."},
      {"name": "IsSynthetic", "type": "bool", "required": true, "example": true, "description": "Always true for this demo pack."},
      {"name": "BusinessContext", "type": "string", "required": false, "example": "Late afternoon vendor deadline pressure.", "description": "Human-readable explanation of business context."},
      {"name": "AdditionalProperties", "type": "dynamic", "required": false, "example": {"BrowserSessionId": "BR-DEVON-001"}, "description": "Workload-specific details stored as JSON/dynamic data."}
    ]
  },
  "entitySchemas": {
    "fileEntity": {
      "description": "Fields for file-centric events.",
      "fields": [
        {"name": "FileName", "type": "string", "example": "Monthly_AML_Review_Workbook_AML-CASE-2026-0519.xlsx"},
        {"name": "FileType", "type": "string", "example": "xlsx"},
        {"name": "FilePath", "type": "string", "example": "/sites/BankingOperations/AML/Monthly_AML_Review_Workbook_AML-CASE-2026-0519.xlsx"},
        {"name": "SiteUrl", "type": "string", "example": "https://contoso.sharepoint.com/sites/BankingOperations"},
        {"name": "LibraryName", "type": "string", "example": "AML Review"},
        {"name": "FileOwner", "type": "string", "example": "priya.sharma@contoso.example"},
        {"name": "SensitivityLabel", "type": "string", "example": "Highly Confidential - Regulated Financial Data"},
        {"name": "PreviousSensitivityLabel", "type": "string", "example": "Confidential"},
        {"name": "ContentPatternSummary", "type": "string", "example": "Contains fictional AML case IDs, SAR draft IDs, customer IDs, and account-like values."}
      ]
    },
    "communicationEntity": {
      "description": "Fields for email, Teams, Viva Engage, Loop, and communication events.",
      "fields": [
        {"name": "MessageId", "type": "string", "example": "MSG-FIC-000441"},
        {"name": "ThreadId", "type": "string", "example": "THREAD-FIC-AML-REVIEW"},
        {"name": "Subject", "type": "string", "example": "AML review summary for operations"},
        {"name": "Recipient", "type": "string", "example": "ops.partner@example.test"},
        {"name": "TargetDomain", "type": "string", "example": "example.test"},
        {"name": "ChannelName", "type": "string", "example": "Banking Operations - General"},
        {"name": "MessagePreview", "type": "string", "example": "Can we send the KYC packet to the vendor today?"},
        {"name": "HasAttachment", "type": "bool", "example": true},
        {"name": "AttachmentName", "type": "string", "example": "Full_KYC_Packet_KYC-FIC-88421_Internal.pdf"}
      ]
    },
    "aiInteractionEntity": {
      "description": "Fields for Copilot and external AI activity.",
      "fields": [
        {"name": "InteractionType", "type": "string", "allowedValues": ["CopilotInteraction", "AIAppInteraction"], "example": "AIAppInteraction"},
        {"name": "PromptText", "type": "string", "example": "Summarize these AML rows..."},
        {"name": "ResponsePreview", "type": "string", "example": "The review identified transaction behavior requiring additional validation."},
        {"name": "SourceFiles", "type": "dynamic", "example": [{"FileName": "Monthly_AML_Review_Workbook_AML-CASE-2026-0519.xlsx", "SensitivityLabel": "Highly Confidential - Regulated Financial Data"}]},
        {"name": "AppName", "type": "string", "example": "External AI App"},
        {"name": "IsManagedApp", "type": "bool", "example": false},
        {"name": "PromptContainsSensitivePattern", "type": "bool", "example": true},
        {"name": "SensitivePatternCount", "type": "int", "example": 4}
      ]
    },
    "dlpEntity": {
      "description": "Fields for DLP events.",
      "fields": [
        {"name": "PolicyName", "type": "string", "example": "Regulated Financial Data External Sharing"},
        {"name": "RuleName", "type": "string", "example": "Block external sharing of KYC and account-like values"},
        {"name": "DlpAction", "type": "string", "allowedValues": ["Audit", "Warn", "Block", "Override"], "example": "Block"},
        {"name": "MatchedSensitiveInfoTypes", "type": "dynamic", "example": ["Fictional Customer ID", "Fictional Account Number", "Fictional AML Case ID"]},
        {"name": "OverrideJustification", "type": "string", "example": "Urgent vendor review requested by operations."},
        {"name": "PolicyTipShown", "type": "bool", "example": true}
      ]
    },
    "endpointEntity": {
      "description": "Fields for endpoint DLP and device movement events.",
      "fields": [
        {"name": "DeviceId", "type": "string", "example": "DEV-FIC-2219"},
        {"name": "DeviceName", "type": "string", "example": "DEVON-LT-2219"},
        {"name": "DeviceComplianceState", "type": "string", "example": "Compliant"},
        {"name": "EndpointAction", "type": "string", "example": "FileCopiedToNetworkShare"},
        {"name": "DestinationPath", "type": "string", "example": "\\\\fileshare-demo\\ops-temp"},
        {"name": "PrinterName", "type": "string", "example": "PRN-FIC-FLOOR12-01"},
        {"name": "RemovableMediaId", "type": "string", "example": "USB-FIC-0007"}
      ]
    },
    "identityEntity": {
      "description": "Fields for sign-in, Conditional Access, guest, and identity-risk events.",
      "fields": [
        {"name": "SignInId", "type": "string", "example": "SIGNIN-FIC-8841"},
        {"name": "Location", "type": "string", "example": "Unusual location - synthetic"},
        {"name": "RiskDetail", "type": "string", "example": "Unfamiliar sign-in properties"},
        {"name": "ConditionalAccessResult", "type": "string", "example": "MFA required"},
        {"name": "MfaSatisfied", "type": "bool", "example": true},
        {"name": "GuestUser", "type": "string", "example": "vendor.pm@northbridge-example.test"},
        {"name": "AccessReviewResult", "type": "string", "example": "Remove access"}
      ]
    },
    "powerBiEntity": {
      "description": "Fields for Power BI activity.",
      "fields": [
        {"name": "ReportName", "type": "string", "example": "Credit Risk Executive Dashboard"},
        {"name": "WorkspaceName", "type": "string", "example": "Risk Analytics"},
        {"name": "DatasetName", "type": "string", "example": "Synthetic Credit Exposure Dataset"},
        {"name": "ExportType", "type": "string", "example": "UnderlyingDataExport"},
        {"name": "ExportFileName", "type": "string", "example": "PowerBI_Customer_Level_Credit_Export.csv"}
      ]
    }
  },
  "normalizedOperations": [
    "FileCreated",
    "FileModified",
    "FileAccessed",
    "FileDownloaded",
    "FileShared",
    "AnonymousLinkCreated",
    "SecureLinkUsed",
    "FilePrinted",
    "FileCopiedToNetworkShare",
    "FileCopiedToUSB",
    "SensitivityLabelApplied",
    "SensitivityLabelChanged",
    "SensitivityLabelRemoved",
    "SensitivityLabelRecommended",
    "LabelDowngrade",
    "DLPPolicyMatch",
    "DLPWarned",
    "DLPBlocked",
    "DLPOverride",
    "EndpointDLPPolicyMatch",
    "CopilotInteraction",
    "AIAppInteraction",
    "UnmanagedAppUpload",
    "SensitiveContentAccessed",
    "FileReferencedByCopilot",
    "RiskySignIn",
    "ConditionalAccessTriggered",
    "MFARequired",
    "GuestUserAdded",
    "ExternalUserAccessed",
    "AccessReviewRequired",
    "AccessReviewCompleted",
    "EmailSent",
    "ExternalEmailSent",
    "TeamsMessageSent",
    "TeamsFileShared",
    "CommunicationComplianceMatch",
    "PowerBIReportViewed",
    "PowerBIExport",
    "UnderlyingDataExport",
    "MassDownloadActivity",
    "InsiderRiskSequence",
    "HRSignal",
    "AfterHoursSensitiveActivity"
  ],
