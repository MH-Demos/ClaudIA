  ],
  "storageTargets": [
    {
      "target": "Azure Data Explorer",
      "recommendedTable": "SyntheticM365ActivityEvents",
      "notes": ["Use dynamic type for AdditionalProperties and arrays.", "Create update policies for derived fact tables if needed.", "Partition or filter by TimeGenerated and ScenarioId for replay performance."]
    },
    {
      "target": "Log Analytics",
      "recommendedTable": "SyntheticM365ActivityEvents_CL",
      "notes": ["Use _CL suffix for custom logs.", "Flatten high-value fields for KQL simplicity.", "Keep AdditionalProperties as dynamic JSON text if needed."]
    },
    {
      "target": "Power BI",
      "recommendedTables": ["FactActivityEvents", "DimUser", "DimScenario", "DimSignal", "DimFile", "DimDate"],
      "notes": ["Split normalized events into facts and dimensions for efficient reporting.", "Use ScenarioId and CorrelationId for drillthrough and timeline visuals."]
    }
  ],
  "codexUsageGuidance": [
    "Use this schema as the canonical output contract for browser-agent telemetry generation.",
    "Generate one event per meaningful user action or system signal.",
    "When real telemetry is unavailable, emit synthetic events using this schema for replay and reporting.",
    "Preserve ScenarioId, TaskPlanId, TimelineId, and CorrelationId across chained activities.",
    "Store workload-specific details in AdditionalProperties instead of creating many sparse columns.",
    "Validate every Operation against normalizedOperations.",
    "Do not include real customer data, real account numbers, real credentials, real secrets, real legal matters, or real employee records."
  ]
}
