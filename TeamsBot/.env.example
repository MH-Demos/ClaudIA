PORT=3978
MicrosoftAppType=MultiTenant
MicrosoftAppId=00000000-0000-0000-0000-000000000000
MicrosoftAppPassword=replace-with-client-secret
MicrosoftAppTenantId=00000000-0000-0000-0000-000000000000

# Optional comma-separated allow list. Values can be Teams AAD object IDs,
# user principal names, or Teams display names. Leave empty only for lab tests.
CLAUDIA_ALLOWED_USERS=

# Repository root used by the bot when executing scripts.
CLAUDIA_REPO_ROOT=C:\Path\To\ClaudIA
CLAUDIA_BOT_CONFIG=
CLAUDIA_CONFIG_PATH=
CLAUDIA_INSTALLATION_DEFINITIONS_PATH=
CLAUDIA_SUBSCRIPTION_ID=
CLAUDIA_ADX_SUBSCRIPTION_ID=
CLAUDIA_BROWSER_AGENTS_SUBSCRIPTION_ID=

# pwsh is preferred. Use powershell.exe only if the host does not have PowerShell 7.
CLAUDIA_POWERSHELL=pwsh
CLAUDIA_COMMAND_TIMEOUT_SECONDS=900
CLAUDIA_OUTPUT_MAX_CHARS=3500
